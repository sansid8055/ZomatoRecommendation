# LLM (Phase 3+) — Groq
LLM_PROVIDER=groq
GROQ_API_KEY=gsk-your-key-here
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=60

# Recommendation limits
MAX_CANDIDATES=25
TOP_K_RESULTS=5

# Data cache (Phase 1)
DATA_CACHE_PATH=./data/processed/restaurants.parquet
# Multi-city HF dataset; ingestion keeps Hyderabad rows only (see DATA_METRO_FILTER)
HF_DATASET_ID=ManikaSaini/zomato-restaurant-recommendation
DEFAULT_METRO_CITY=Bangalore
DATA_METRO_FILTER=Bangalore
